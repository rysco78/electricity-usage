[Unit]
Description=Energy Plan Optimizer
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/electricity-usage
EnvironmentFile=/home/ubuntu/electricity-usage/.env
ExecStart=/home/ubuntu/electricity-usage/.venv/bin/uvicorn app:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
